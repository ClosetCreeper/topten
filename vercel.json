{
  "version": 2,
  "rewrites": [
    {
      "source": "/trip/:id",
      "destination": "/trip.html"
    },
    {
      "source": "/photo/share/:photoID",
      "destination": "/photo/share/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
